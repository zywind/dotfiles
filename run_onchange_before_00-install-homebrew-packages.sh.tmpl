#!/bin/bash
# Bootstrap only the platform-level tools needed before mise can take over.
# Portable developer CLIs and runtimes are declared in ~/.config/mise/config.toml.
set -eufo pipefail

export PATH="$HOME/.local/bin:$PATH"

{{ if eq .chezmoi.os "darwin" -}}
# Homebrew owns the macOS bootstrap layer: git, tmux, mise, chezmoi, and the
# small number of tools that are not managed portably by mise.
if ! command -v brew >/dev/null 2>&1 && [ ! -x /opt/homebrew/bin/brew ] && [ ! -x /usr/local/bin/brew ]; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

for brewbin in /opt/homebrew/bin/brew /usr/local/bin/brew; do
  [ -x "$brewbin" ] && eval "$("$brewbin" shellenv)" && break
done

brew bundle --file=/dev/stdin <<'BREWFILE'
# Bootstrap and shell infrastructure
brew "git"
brew "tmux"
brew "mise"
brew "chezmoi"

# Native macOS exceptions whose current mise release assets are Linux-only or
# x86_64-only. Linux installs their native builds through mise.
brew "code-minimap"
brew "eza"
brew "tlrc"

# macOS terminal and font
cask "iterm2"
cask "font-hack-nerd-font"
BREWFILE
{{ else if eq .chezmoi.os "linux" -}}
# Linux only needs a small system foundation. The dev-machine image runs as
# root; on a normal workstation use sudo when not already root.
if command -v apt-get >/dev/null 2>&1; then
  apt=(apt-get)
  if [ "$(id -u)" -ne 0 ]; then
    command -v sudo >/dev/null 2>&1 || { echo "sudo is required to install Linux bootstrap packages" >&2; exit 1; }
    apt=(sudo apt-get)
  fi
  "${apt[@]}" update -qq
  DEBIAN_FRONTEND=noninteractive "${apt[@]}" install -y \
    ca-certificates curl git tmux zsh build-essential
fi

if ! command -v mise >/dev/null 2>&1; then
  curl -fsSL https://mise.run | sh
fi

# This toolset relies on registry entries bundled with mise 2026.7.6+. Pin the
# minimum bootstrap version without downgrading a newer installation.
required_mise="2026.7.6"
current_mise="$(mise --version | awk '{print $1}')"
if [ "$(printf '%s\n' "$required_mise" "$current_mise" | sort -V | head -n1)" != "$required_mise" ]; then
  mise self-update "$required_mise" --yes --no-plugins
fi

if ! command -v chezmoi >/dev/null 2>&1; then
  sh -c "$(curl -fsLS get.chezmoi.io)" -- -b "$HOME/.local/bin"
fi
{{ end -}}

command -v mise >/dev/null 2>&1 || { echo "mise bootstrap failed" >&2; exit 1; }
