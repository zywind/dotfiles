# === Oh-My-Zsh ===
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME=""
plugins=(git fzf-tab zsh-autosuggestions zsh-syntax-highlighting)
source $ZSH/oh-my-zsh.sh

# === fzf-tab ===
# disable sort when completing `git checkout`
zstyle ':completion:*:git-checkout:*' sort false
# show file content preview when completing paths
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls -1 --color=always $realpath'
# switch groups with < and >
zstyle ':fzf-tab:*' switch-group '<' '>'

# === Tools ===

# fnm (Fast Node Manager)
eval "$(fnm env --use-on-cd --shell zsh)"

# fzf
source <(fzf --zsh)

# uv shell completion
eval "$(uv generate-shell-completion zsh)"

# bun completions
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# starship prompt
eval "$(starship init zsh)"

# zoxide (smart cd: `z`, `zi`)
eval "$(zoxide init zsh)"

# direnv (per-directory env)
eval "$(direnv hook zsh)"

# === Aliases ===
alias python='python3'
alias tf="terraform"
alias cat='bat --paging=never'
# eza (modern ls) — non-shadowing names, leaves `ls` intact
alias ll='eza -lah --git --group-directories-first'
alias la='eza -a'
alias lt='eza --tree --level=2'

# === Hooks ===

# ssh-agent: start if not already running
if [ -z "$SSH_AUTH_SOCK" ]; then
  RUNNING_AGENT="$(ps -ax | grep 'ssh-agent -s' | grep -v grep | wc -l | tr -d '[:space:]')"
  if [ "$RUNNING_AGENT" = "0" ]; then
    ssh-agent -s &> $HOME/.ssh/ssh-agent
  fi
  eval "$(cat $HOME/.ssh/ssh-agent)" > /dev/null
  ssh-add $HOME/.ssh/id_rsa 2> /dev/null
fi

# === Secrets & Work ===
[ -f ~/.env.secrets ] && source ~/.env.secrets
[ -f ~/.zshrc.work ] && source ~/.zshrc.work
