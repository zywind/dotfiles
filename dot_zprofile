# PATH and environment setup for login shells on macOS and Linux.
# Interactive hooks and completions belong in .zshrc.

typeset -U path PATH

# Use the same configuration root on macOS and Linux.
export XDG_CONFIG_HOME="$HOME/.config"

# Preserve ephemeral credentials and helper binaries supplied by dev-machine.
[[ -r /opt/devmachine_assets/env/forwarded-session.sh ]] && source /opt/devmachine_assets/env/forwarded-session.sh
[[ -d /opt/devmachine_assets/bin ]] && path=(/opt/devmachine_assets/bin $path)

# Homebrew is the macOS bootstrap package manager. Linux tools are installed
# directly by apt or mise.
for brewbin in /opt/homebrew/bin/brew /usr/local/bin/brew; do
  [[ -x "$brewbin" ]] && eval "$("$brewbin" shellenv)" && break
done

# mise itself and its shims must work in login, non-interactive, and recovery
# shells. Interactive shells replace the shims with version-specific paths.
path=($HOME/.local/bin $HOME/.local/share/mise/shims $path)

export EDITOR='nvim'
export VISUAL='nvim'
