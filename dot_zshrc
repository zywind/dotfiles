# Load login-shell environment in non-login interactive shells.
if [[ ! -o login ]] && [[ -f "$HOME/.zprofile" ]]; then
  source "$HOME/.zprofile"
fi

# Personal and work-specific additions are intentionally not managed here.
[[ -f ~/.env.secrets ]] && source ~/.env.secrets
[[ -f ~/.zshrc.work ]] && source ~/.zshrc.work
alias python='python3'

[[ -o interactive ]] || return

# === Oh My Zsh ===
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME=""
plugins=(git fzf-tab zsh-autosuggestions zsh-syntax-highlighting)
[[ -r "$ZSH/oh-my-zsh.sh" ]] && source "$ZSH/oh-my-zsh.sh"

# === History ===
HISTSIZE=100000
SAVEHIST=100000
setopt SHARE_HISTORY EXTENDED_HISTORY HIST_VERIFY
setopt HIST_IGNORE_ALL_DUPS HIST_IGNORE_SPACE HIST_REDUCE_BLANKS

# === Environment ===
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers --line-range :200 {}'"
export FZF_ALT_C_OPTS="--preview 'eza --tree --color=always --level=2 {}'"
export MANPAGER="sh -c 'col -bx | bat -l man -p'"
export MANROFFOPT="-c"

# === Shell integrations ===
# mise must activate before tools it manages and before direnv adjusts PATH.
(( $+commands[mise] )) && eval "$(mise activate zsh)"
(( $+commands[uv] )) && eval "$(uv generate-shell-completion zsh)"
(( $+commands[zoxide] )) && eval "$(zoxide init zsh)"
(( $+commands[direnv] )) && eval "$(direnv hook zsh)"
(( $+commands[starship] )) && eval "$(starship init zsh)"
(( $+commands[fzf] )) && source <(fzf --zsh)

# === Completion styling ===
zstyle ':completion:*:git-checkout:*' sort false
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
zstyle ':fzf-tab:*' switch-group '<' '>'

# === Aliases ===
# Oh My Zsh adds a colored grep alias; keep grep as the unmodified system tool.
unalias grep 2>/dev/null
alias v='nvim'
alias k='kubectl'
alias cat='bat --paging=never'
alias ls='eza --icons --group-directories-first'
alias ll='eza -lah --icons --git --git-repos --header --smart-group --color-scale=all --time-style=relative --group-directories-first'
alias la='eza -a --icons --group-directories-first'
alias lt='eza --tree --icons --level=2 --group-directories-first'
alias lsize='eza -lah --icons --sort=size --reverse'
alias lmod='eza -lah --icons --sort=modified'
alias ltt='eza --tree --icons --level=3 --git-ignore'
alias lg='lazygit'
(( $+commands[ouch] )) && alias x='ouch decompress'

# dev-machine forwards credentials through its managed asset tree. Elsewhere,
# reuse a local ssh-agent and add the first conventional personal key present.
if [[ -z "${DEV_MACHINE_ASSETS:-}" && -z "$SSH_AUTH_SOCK" ]]; then
  mkdir -p "$HOME/.ssh"
  if ! pgrep -u "$USER" ssh-agent >/dev/null 2>&1; then
    ssh-agent -s >"$HOME/.ssh/ssh-agent"
  fi
  [[ -r "$HOME/.ssh/ssh-agent" ]] && eval "$(<"$HOME/.ssh/ssh-agent")" >/dev/null
  for key in "$HOME/.ssh/id_ed25519" "$HOME/.ssh/id_rsa"; do
    [[ -r "$key" ]] && { ssh-add "$key" 2>/dev/null; break; }
  done
fi
