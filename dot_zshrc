# === Load login-shell env in non-login shells ===
# zsh sources .zprofile only for LOGIN shells. macOS terminals (iTerm2) open
# login shells, but most Linux terminals (GNOME Terminal, etc.) open non-login
# interactive shells — which would otherwise miss PATH/Homebrew setup and fail
# to find git, starship, fnm, … Source it ourselves only when not a login shell
# (login shells already ran it, so this is a no-op there — e.g. on macOS).
if [[ ! -o login ]] && [[ -f "$HOME/.zprofile" ]]; then
  source "$HOME/.zprofile"
fi

# === Always-on (interactive AND non-interactive) ===
# Above the interactive guard so scripts and tools that source .zshrc
# (e.g. snapshotting harnesses) still get these.
[[ -f ~/.env.secrets ]] && source ~/.env.secrets   # API keys / env, needed by scripts
[[ -f ~/.zshrc.work ]] && source ~/.zshrc.work      # work-specific config
alias grep='ugrep'                                  # fast, grep-compatible drop-in
alias python='python3'                              # used by scripts too

# Everything below is for interactive shells only (prompt, completions, tool
# hooks, human-facing aliases). Standard zsh already skips .zshrc for
# non-interactive shells; this also guards harnesses that source it anyway.
[[ -o interactive ]] || return

# === Oh My Zsh ===
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME=""   # prompt is handled by starship
plugins=(git fzf-tab zsh-autosuggestions zsh-syntax-highlighting)
source "$ZSH/oh-my-zsh.sh"

# === History ===
HISTSIZE=100000
SAVEHIST=100000
setopt SHARE_HISTORY EXTENDED_HISTORY HIST_VERIFY
setopt HIST_IGNORE_ALL_DUPS HIST_IGNORE_SPACE HIST_REDUCE_BLANKS

# === Environment ===
# fzf: source files/dirs via fd (fast, respects .gitignore); preview with bat/eza
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers --line-range :200 {}'"
export FZF_ALT_C_OPTS="--preview 'eza --tree --color=always --level=2 {}'"
# bat: syntax-highlighted man pages
export MANPAGER="sh -c 'col -bx | bat -l man -p'"
export MANROFFOPT="-c"

# === Shell integrations ===
eval "$(fnm env --use-on-cd --shell zsh)"   # node version manager
eval "$(uv generate-shell-completion zsh)"  # uv completions
eval "$(zoxide init zsh)"                    # smart cd: z, zi
eval "$(direnv hook zsh)"                    # per-directory env
eval "$(starship init zsh)"                  # prompt
source <(fzf --zsh)                          # fzf keybindings + completion
[[ -s "$HOME/.bun/_bun" ]] && source "$HOME/.bun/_bun"  # bun completions

# === Completion styling (fzf-tab) ===
zstyle ':completion:*:git-checkout:*' sort false                              # keep branches in ref order
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath' # preview dir contents
zstyle ':fzf-tab:*' switch-group '<' '>'                                      # switch groups with < >

# === Aliases ===
alias v='nvim'
alias tf='terraform'
alias grep='ugrep'                                   # re-assert over oh-my-zsh's grep alias
alias cat='bat --paging=never'                       # highlighted cat (plain when piped)
alias ls='eza'                                       # eza as ls — safe: interactive-only via guard
alias ll='eza -lah --git --group-directories-first'  # long, all, git status
alias la='eza -a'                                    # all incl. dotfiles
alias lt='eza --tree --level=2'                      # tree, 2 levels deep
alias x='ouch decompress'                            # extract any archive
alias lg='lazygit'                                   # git TUI

# === ssh-agent ===
# Reuse a running agent, or start one and cache its env in ~/.ssh/ssh-agent
if [[ -z "$SSH_AUTH_SOCK" ]]; then
  if ! pgrep -u "$USER" ssh-agent >/dev/null; then
    ssh-agent -s >"$HOME/.ssh/ssh-agent"
  fi
  [[ -r "$HOME/.ssh/ssh-agent" ]] && eval "$(<"$HOME/.ssh/ssh-agent")" >/dev/null
  ssh-add "$HOME/.ssh/id_rsa" 2>/dev/null
fi
